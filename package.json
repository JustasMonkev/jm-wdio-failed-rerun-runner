{
  "name": "jm-wdio-failed-rerun-runner",
  "version": "0.1.0",
  "description": "A WebdriverIO helper that reruns only tests that failed in the initial run.",
  "license": "MIT",
  "author": "Justas <justaskietas123@gmail.com>",
  "engines": {
    "node": ">=18.20.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justaskietas/jm-wdio-failed-rerun-runner.git"
  },
  "keywords": [
    "webdriver",
    "webdriverio",
    "wdio",
    "rerun",
    "retry"
  ],
  "bin": {
    "wdio-failed-rerun-runner": "./build/cli.js"
  },
  "type": "module",
  "imports": {
    "#src/*": {
      "types": "./src/*.ts",
      "default": "./build/*.js"
    }
  },
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js"
    },
    "./run": {
      "types": "./build/run.d.ts",
      "import": "./build/run.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm run coverage",
    "lint": "eslint .",
    "prepack": "npm run build",
    "test": "npm run build && vitest run tests",
    "coverage": "vitest run tests --coverage",
    "typecheck": "tsc -p tsconfig.test.json --noEmit"
  },
  "files": [
    "build",
    "src",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@wdio/cli": "^9.28.0",
    "@wdio/types": "^9.28.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.1",
    "jiti": "^2.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
